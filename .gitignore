# =============================================================================
# ShadowDesk .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
.eggs/
dist/
build/
*.whl
pip-log.txt
pip-delete-this-directory.txt
.tox/
.nox/
.hypothesis/
.pytest_cache/

# Virtual environments
venv/
.venv/
env/
ENV/
env.bak/
venv.bak/

# Jupyter Notebook
.ipynb_checkpoints

# -----------------------------------------------------------------------------
# IDEs
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# -----------------------------------------------------------------------------
# Environment & Secrets
# -----------------------------------------------------------------------------
.env
.env.local
.env.[!local]*
.envrc
.secrets/
*.secrets
credentials.json

# -----------------------------------------------------------------------------
# Kubernetes
# -----------------------------------------------------------------------------
kubeconfig
*.kubeconfig
kind-config.yaml
config/kind-config.yaml
kubectl*
config/kind-config.yaml

# Sealed Secrets (source secrets - NOT committed)
k8s/bootstrap/
k8s/sealed-secrets/*.pem
k8s/bootstrap/secrets-source.yaml

# Sealed Secrets (encrypted - SAFE to commit)
!k8s/sealed-secrets/shadowdesk-secrets.yaml

# -----------------------------------------------------------------------------
# Helm
# -----------------------------------------------------------------------------
charts/
tmpcharts/
*charts/
shadowdesk-infra/charts/
shadowdesk-compute/charts/

# -----------------------------------------------------------------------------
# Local Development
# -----------------------------------------------------------------------------
*.md
!README.md
.shadowdesk/
.ngrok/
.ngrok2/
tmp/
temp/
*.log
logs/

# -----------------------------------------------------------------------------
# Documentation Builds
# -----------------------------------------------------------------------------
site/
_build/
*.html

# -----------------------------------------------------------------------------
# Testing & Coverage
# -----------------------------------------------------------------------------
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover
.nyc_output/

# -----------------------------------------------------------------------------
# CI/CD
# -----------------------------------------------------------------------------
.github/workflows/*.local.yml

# -----------------------------------------------------------------------------
# Misc
# -----------------------------------------------------------------------------
*.bak
*.tmp
*.orig
*~
\#*\#
